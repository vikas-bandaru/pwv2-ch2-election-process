<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'CivicLogic' %> | CivicLogic</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --eci-blue: #003399;
            --eci-orange: #FF9933;
            --eci-green: #138808;
            --glass-bg: rgba(255, 255, 255, 0.8);
        }
        body { font-family: 'Outfit', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }
        .bg-eci-blue { background-color: var(--eci-blue); }
        .text-eci-blue { color: var(--eci-blue); }
        .border-eci-blue { border-color: var(--eci-blue); }
        
        .animate-fade-in { animation: fadeIn 0.5s ease-out forwards; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .glass-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        /* News Styles */
        .news-newspaper {
            background: #fdfaf3;
            border: 1px solid #e5e0d5;
            box-shadow: 5px 5px 0px #e5e0d5;
            font-family: 'Playfair Display', serif;
        }
        .news-mobile {
            background: #111;
            color: #fff;
            border-radius: 2rem;
            border: 4px solid #333;
        }
        .news-website {
            background: #fff;
            border-top: 4px solid var(--eci-blue);
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.1);
        }
        .news-item-active {
            outline: 4px solid var(--eci-blue);
            transform: scale(1.02);
            z-index: 10;
        }

        /* ── LogicAnalogy Tooltip Component ──────────────────────────── */
        .logic-analogy {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            position: relative;
            cursor: help;
            border-bottom: 2px dashed var(--eci-orange);
            font-weight: 700;
        }
        .logic-analogy::before {
            content: '💡';
            font-size: 0.7rem;
        }
        .logic-analogy .analogy-bubble {
            display: none;
            position: absolute;
            bottom: calc(100% + 8px);
            left: 50%;
            transform: translateX(-50%);
            background: #1a1a2e;
            color: #fff;
            border-radius: 12px;
            padding: 10px 14px;
            font-size: 0.72rem;
            font-weight: 600;
            white-space: nowrap;
            z-index: 50;
            box-shadow: 0 8px 24px rgba(0,0,0,0.2);
            line-height: 1.4;
            text-align: center;
            min-width: 160px;
        }
        .logic-analogy .analogy-bubble::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            border: 6px solid transparent;
            border-top-color: #1a1a2e;
        }
        .logic-analogy:hover .analogy-bubble {
            display: block;
            animation: fadeIn 0.2s ease-out;
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
    <header class="bg-eci-blue text-white shadow-lg p-4">
        <div class="container mx-auto flex justify-between items-center gap-4">
            <h1 class="text-2xl font-bold tracking-tight flex-shrink-0">CivicLogic: The One-Vote Simulator</h1>

            <div class="flex items-center gap-3 flex-wrap justify-end">
                <!-- Demo notice — shown always -->
                <div class="flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 text-xs font-semibold">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-300 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-yellow-400"></span>
                    </span>
                    Live Demo Preview
                </div>

                <% if (locals.voterName) { %>
                    <div class="text-sm font-medium opacity-90">
                        👤 <span class="font-bold"><%= locals.voterName %></span>
                    </div>
                <% } %>
            </div>
        </div>
    </header>

    <main class="flex-grow container mx-auto p-6">
