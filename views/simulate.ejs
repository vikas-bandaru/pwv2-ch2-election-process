<%- include('partials/header') %>

<div class="max-w-4xl mx-auto">
    <!-- Progress Stepper -->
    <div class="mb-12 flex justify-between">
        <% const stages = ['ANNOUNCEMENT', 'PREP', 'CAMPAIGN', 'POLL', 'COUNTING']; %>
        <% stages.forEach((s, i) => { %>
            <div class="flex flex-col items-center flex-1">
                <div class="w-10 h-10 rounded-full flex items-center justify-center <%= state === s ? 'bg-eci-blue text-white ring-4 ring-blue-100' : (stages.indexOf(state) > i ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-500') %>">
                    <% if (stages.indexOf(state) > i) { %>
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <% } else { %>
                        <%= i + 1 %>
                    <% } %>
                </div>
                <span class="text-xs mt-2 font-bold <%= state === s ? 'text-eci-blue' : 'text-gray-400' %>"><%= s %></span>
            </div>
            <% if (i < stages.length - 1) { %>
                <div class="h-1 flex-grow mt-5 <%= stages.indexOf(state) > i ? 'bg-green-500' : 'bg-gray-200' %>"></div>
            <% } %>
        <% }) %>
    </div>

    <!-- Stage Content -->
    <div class="bg-white rounded-2xl shadow-xl p-10 border-l-8 border-eci-blue">
        <% if (state === 'ANNOUNCEMENT') { %>
            <div class="space-y-8">
                <% if (!voterData.location.state) { %>
                    <div class="space-y-6">
                        <div class="inline-block px-3 py-1 bg-blue-100 text-eci-blue rounded-full text-sm font-bold tracking-wider uppercase">Voter Verification</div>
                        <h2 class="text-3xl font-extrabold text-gray-900 leading-tight">Where are you voting from?</h2>
                        <p class="text-lg text-gray-600">To show you the correct election schedule and local context, please enter your constituency details.</p>
                        
                        <form action="/simulate/next-stage" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <input type="hidden" name="action" value="SET_LOCATION">
                            
                            <div class="space-y-2">
                                <label class="block text-sm font-bold text-gray-700">Select State</label>
                                <select name="state" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-eci-blue outline-none transition">
                                    <option value="" disabled selected>Choose your state</option>
                                    <option value="West Bengal">West Bengal</option>
                                    <option value="Tamil Nadu">Tamil Nadu</option>
                                    <option value="Kerala">Kerala</option>
                                    <option value="Assam">Assam</option>
                                    <option value="Puducherry">Puducherry</option>
                                </select>
                            </div>

                            <div class="space-y-2">
                                <label class="block text-sm font-bold text-gray-700">Constituency Name</label>
                                <input type="text" name="constituency" required placeholder="e.g. Nallagandla" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-eci-blue outline-none transition">
                            </div>

                            <div class="space-y-2">
                                <label class="block text-sm font-bold text-gray-700">Pin Code</label>
                                <input type="text" name="pinCode" required pattern="[0-9]{6}" placeholder="6-digit PIN" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-eci-blue outline-none transition">
                            </div>

                            <div class="md:col-span-2 pt-4">
                                <button type="submit" class="w-full bg-eci-blue text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-800 transition shadow-lg hover:shadow-xl transform hover:-translate-y-1">
                                    VERIFY LOCATION & FETCH NEWS →
                                </button>
                                <p class="text-center text-[10px] text-gray-400 mt-3">After verifying, you can choose your simulation start date from the news feed.</p>
                            </div>
                        </form>
                    </div>
                <% } else { %>
                    <div class="space-y-8 animate-fade-in">
                        <div class="flex items-center gap-2 px-4 py-2 bg-red-100 text-red-600 rounded-full w-fit">
                            <span class="relative flex h-3 w-3">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-3 w-3 bg-red-600"></span>
                            </span>
                            <span class="text-xs font-black uppercase tracking-widest">Election Dashboard Live</span>
                        </div>

                        <!-- Premium News Card (AI Generated Headline) -->
                        <div class="relative overflow-hidden bg-white border border-gray-100 rounded-3xl p-8 shadow-xl group hover:shadow-2xl transition-all duration-500">
                            <div class="absolute -right-12 -top-12 w-64 h-64 bg-eci-blue/5 rounded-full blur-3xl group-hover:bg-eci-blue/10 transition-colors"></div>
                            
                            <div class="relative flex flex-col gap-6">
                                <div class="space-y-2">
                                    <h3 class="text-4xl font-black text-gray-900 leading-tight">
                                        <%= extraData.electionAnnouncement.headline %>
                                    </h3>
                                    <p class="text-xl text-gray-600 font-medium leading-relaxed">
                                        <%= extraData.electionAnnouncement.summary %>
                                    </p>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-2xl border border-gray-100">
                                        <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-eci-blue">
                                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                        </div>
                                        <div>
                                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Polling Date</p>
                                            <p class="text-lg font-black text-gray-900"><%= extraData.electionTimeline.pollDate %></p>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-4 bg-gray-50 p-4 rounded-2xl border border-gray-100">
                                        <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center <%= extraData.electionTimeline.daysToPoll > 0 ? 'text-green-600' : 'text-red-600' %>">
                                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        </div>
                                        <div class="flex-grow">
                                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Election Status</p>
                                            <p class="text-lg font-black text-gray-900">
                                                <%= extraData.electionTimeline.daysToPoll > 0 ? extraData.electionTimeline.daysToPoll + ' Days Left' : 'Poll Concluded' %>
                                            </p>
                                        </div>
                                        <div class="text-right">
                                            <a href="/simulate/reset" class="text-[10px] font-black text-eci-blue uppercase tracking-widest hover:underline">Change</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Timeline News Feed — Choose Your Simulation Date -->
                        <div class="space-y-4">
                            <div class="flex items-center gap-3">
                                <div class="h-px flex-1 bg-gray-100"></div>
                                <p class="text-xs font-black uppercase tracking-widest text-gray-400">📅 Choose Your Simulation Start Date</p>
                                <div class="h-px flex-1 bg-gray-100"></div>
                            </div>
                            <p class="text-sm text-gray-500 text-center">Each news item below represents a real moment in the <strong><%= voterData.location.state %></strong> election cycle. Click the one that matches where you want to begin your journey.</p>

                            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-2">
                                <% extraData.newsPhases.forEach((phase, i) => { %>
                                    <% 
                                        const isActive = voterData.simulationDate === phase.isoDate;
                                        const typeClasses = phase.type === 'newspaper' ? 'news-newspaper' : (phase.type === 'mobile' ? 'news-mobile' : 'news-website');
                                    %>
                                    <form action="/simulate/next-stage" method="POST" class="contents" id="phaseForm<%= i %>">
                                        <input type="hidden" name="action" value="SET_DATE">
                                        <input type="hidden" name="simulationDate" value="<%= phase.isoDate %>">
                                        <button type="submit" class="<%= typeClasses %> <%= isActive ? 'news-item-active' : '' %> p-6 cursor-pointer transition-all text-left w-full group relative overflow-hidden">
                                            <% if (phase.type === 'newspaper') { %>
                                                <p class="text-[10px] uppercase tracking-tighter text-gray-500 mb-1"><%= phase.source %> • <%= phase.date %></p>
                                                <div class="w-full h-px bg-gray-200 mb-3"></div>
                                                <h4 class="font-serif text-lg font-bold text-gray-900 leading-snug mb-3 group-hover:text-eci-blue transition-colors"><%= phase.headline %></h4>
                                                <p class="text-[10px] text-gray-600 leading-snug"><%= phase.body %></p>
                                                <p class="text-[9px] font-black text-eci-blue uppercase tracking-widest mt-4 opacity-70"><%= phase.phase %></p>
                                            <% } else if (phase.type === 'mobile') { %>
                                                <div class="absolute top-2 left-1/2 -translate-x-1/2 w-10 h-3 bg-gray-700 rounded-full"></div>
                                                <div class="mt-5 space-y-2">
                                                    <div class="flex items-center gap-2">
                                                        <div class="w-2 h-2 bg-red-400 rounded-full animate-pulse"></div>
                                                        <span class="text-[8px] font-black tracking-widest uppercase text-gray-400"><%= phase.source %></span>
                                                        <span class="ml-auto text-[8px] text-gray-500"><%= phase.date %></span>
                                                    </div>
                                                    <h4 class="text-sm font-black text-white leading-tight"><%= phase.headline %></h4>
                                                    <p class="text-[9px] text-gray-400 leading-snug"><%= phase.body %></p>
                                                    <p class="text-[9px] font-black text-eci-orange uppercase tracking-widest mt-2"><%= phase.phase %></p>
                                                </div>
                                            <% } else { %>
                                                <div class="flex items-center justify-between mb-3 pb-2 border-b border-gray-100">
                                                    <span class="text-[8px] font-black text-eci-blue uppercase tracking-widest"><%= phase.source %></span>
                                                    <span class="text-[8px] text-gray-400"><%= phase.date %></span>
                                                </div>
                                                <h4 class="text-base font-black text-gray-900 leading-snug mb-2 group-hover:text-eci-blue transition-colors"><%= phase.headline %></h4>
                                                <p class="text-[10px] text-gray-500 leading-snug"><%= phase.body %></p>
                                                <p class="text-[9px] font-black text-eci-blue uppercase tracking-widest mt-4 opacity-70"><%= phase.phase %></p>
                                            <% } %>
                                            <% if (isActive) { %>
                                                <div class="absolute top-2 right-2 w-5 h-5 bg-eci-blue rounded-full flex items-center justify-center">
                                                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                                </div>
                                            <% } %>
                                        </button>
                                    </form>
                                <% }) %>
                            </div>
                            <p class="text-[10px] text-center text-gray-400 italic">Selecting a phase reloads the dashboard with the updated simulation date.</p>
                        </div>

                        <div class="bg-blue-50/50 border border-blue-100 p-6 rounded-2xl flex gap-4 items-start">
                            <div class="text-eci-blue pt-1">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                            <p class="text-blue-900 font-medium">The Election Commission has officially notified the poll schedule for <%= voterData.location.state %>. Ensure you are registered before the deadline.</p>
                        </div>

                        <form action="/simulate/next-stage" method="POST">
                            <input type="hidden" name="action" value="START_PREP">
                            <button type="submit" class="w-full bg-eci-blue text-white px-10 py-6 rounded-2xl font-black text-xl hover:bg-blue-800 transition-all duration-300 shadow-2xl shadow-blue-200 flex items-center justify-center gap-3 group">
                                BEGIN VOTER PREPARATION
                                <svg class="w-6 h-6 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                            </button>
                        </form>
                    </div>
                <% } %>
            </div>
        <% } else if (state === 'PREP') { %>
            <div class="space-y-10 animate-fade-in">
                <div class="flex justify-between items-center border-b border-gray-100 pb-6">
                    <div>
                        <h2 class="text-4xl font-black text-gray-900 tracking-tight">Stage 2: Civic Roadmap</h2>
                        <p class="text-lg text-gray-500 font-medium">Preparing for the democratic exercise in <%= voterData.location.constituency %>.</p>
                    </div>
                    <div class="text-right px-6 py-3 bg-blue-50 rounded-2xl border border-blue-100">
                        <span class="text-[10px] font-black text-eci-blue uppercase tracking-widest block mb-1">Today's Date</span>
                        <div class="text-eci-blue font-black text-xl"><%= extraData.today %></div>
                    </div>
                </div>

                <!-- Vertical Timeline -->
                <div class="relative max-w-2xl mx-auto py-4">
                    <div class="absolute left-6 top-4 bottom-4 w-1 bg-gradient-to-b from-green-500 via-eci-blue to-gray-200 rounded-full"></div>

                    <div class="space-y-12">
                        <% extraData.timeline.forEach((item, index) => { %>
                            <div class="relative flex items-center group">
                                <!-- Status Marker -->
                                <div class="z-10 w-12 h-12 rounded-2xl flex items-center justify-center transition-all duration-500 transform group-hover:scale-110
                                    <%= item.status === 'COMPLETED' ? 'bg-green-500 shadow-xl shadow-green-100 rotate-12' : (item.status === 'CURRENT' ? 'bg-eci-blue shadow-xl shadow-blue-200 -rotate-12 scale-125' : 'bg-white border-4 border-gray-100 text-gray-300') %>">
                                    <% if (item.status === 'COMPLETED') { %>
                                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                    <% } else if (item.status === 'CURRENT') { %>
                                        <div class="w-3 h-3 bg-white rounded-full animate-ping"></div>
                                    <% } else { %>
                                        <span class="font-black text-lg"><%= index + 1 %></span>
                                    <% } %>
                                </div>

                                <!-- Milestone Info -->
                                <div class="ml-8 flex-grow">
                                    <div class="flex items-center gap-3 mb-1">
                                        <h3 class="text-xl font-black <%= item.status === 'FUTURE' ? 'text-gray-400' : 'text-gray-900' %>">
                                            <%= item.label %>
                                        </h3>
                                        <% if (item.status === 'CURRENT') { %>
                                            <span class="px-3 py-1 bg-blue-600 text-white text-[10px] font-black uppercase rounded-full tracking-widest animate-pulse">Live</span>
                                        <% } %>
                                    </div>
                                    <div class="flex items-center gap-2 text-sm <%= item.status === 'FUTURE' ? 'text-gray-300' : 'text-gray-500 font-bold' %>">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                        <%= item.date %>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Eligibility & Action Section -->
                <% if (!extraData.isEnrollmentOpen && !voterData.isRegistered) { %>
                    <!-- INELIGIBLE STATE -->
                    <div class="p-10 bg-red-50 border-2 border-red-200 rounded-[2.5rem] text-center shadow-2xl shadow-red-100 relative overflow-hidden group">
                        <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-red-100 rounded-full blur-3xl opacity-50"></div>
                        
                        <div class="relative z-10">
                            <div class="w-24 h-24 bg-red-100 text-red-600 rounded-3xl flex items-center justify-center mx-auto mb-6 transform -rotate-6 group-hover:rotate-0 transition-transform duration-500">
                                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                </svg>
                            </div>
                            <h3 class="text-4xl font-black text-red-900 mb-4 tracking-tight">Access Restricted</h3>
                            <p class="text-xl text-red-700 mb-8 font-medium max-w-xl mx-auto leading-relaxed">
                                Enrollment for this electoral cycle closed on <span class="font-black underline decoration-red-300 decoration-4"><%= extraData.timeline.find(t => t.key === 'enrollment').date %></span>. 
                                Since you missed the Form 6 deadline, you are ineligible to vote in this simulation.
                            </p>
                            
                            <form action="/simulate/next-stage" method="POST">
                                <input type="hidden" name="action" value="PROVIDE_ID">
                                <input type="hidden" name="hasID" value="">
                                <button type="submit" class="bg-red-600 text-white px-12 py-5 rounded-2xl font-black text-xl hover:bg-red-700 transition shadow-xl hover:shadow-red-200 transform hover:-translate-y-1">
                                    CONTINUE AS OBSERVER
                                </button>
                            </form>
                        </div>
                    </div>
                <% } else { %>
                    <!-- Identity Verification Card -->
                    <div class="bg-white border-2 border-gray-100 rounded-[2.5rem] p-10 shadow-2xl shadow-gray-100">
                        <div class="flex flex-col md:flex-row gap-8 items-center">
                            <div class="flex-1 space-y-4 text-center md:text-left">
                                <% if (voterData.isRegistered) { %>
                                    <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-50 text-green-700 rounded-full text-sm font-black uppercase tracking-widest mb-2">
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                                        Registration Successful
                                    </div>
                                    <h3 class="text-3xl font-black text-gray-900">You are on the E-Roll!</h3>
                                    <p class="text-lg text-gray-500 font-medium leading-relaxed">
                                        Your Form 6 has been processed. You are now eligible to participate in the 2026 Assembly Elections.
                                    </p>
                                <% } else { %>
                                    <h3 class="text-3xl font-black text-gray-900">Identity Verification</h3>
                                    <p class="text-lg text-gray-500 font-medium leading-relaxed">
                                        A valid Voter ID (EPIC) is mandatory to vote. 
                                        <% if (extraData.isEnrollmentOpen) { %>
                                            If you are not registered, you can still apply for Form 6 today.
                                        <% } else { %>
                                            Enrollment for this cycle is now <span class="text-red-600 font-black">CLOSED</span>.
                                        <% } %>
                                    </p>
                                <% } %>
                            </div>
                            
                            <div class="flex flex-col gap-4 w-full md:w-auto min-w-[320px]">
                                <% if (voterData.isRegistered) { %>
                                    <form action="/simulate/next-stage" method="POST">
                                        <input type="hidden" name="action" value="PROVIDE_ID">
                                        <input type="hidden" name="hasID" value="true">
                                        <button type="submit" class="w-full bg-eci-blue text-white px-8 py-5 rounded-2xl font-black text-lg hover:bg-blue-800 transition shadow-xl hover:shadow-blue-100 flex items-center justify-center gap-3 group">
                                            PROCEED TO CAMPAIGN
                                            <svg class="w-6 h-6 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                                        </button>
                                    </form>
                                <% } else { %>
                                    <!-- Positive Path -->
                                    <form action="/simulate/next-stage" method="POST">
                                        <input type="hidden" name="action" value="PROVIDE_ID">
                                        <input type="hidden" name="hasID" value="true">
                                        <button type="submit" class="w-full bg-green-600 text-white px-8 py-5 rounded-2xl font-black text-lg hover:bg-green-700 transition shadow-xl hover:shadow-green-100 flex items-center justify-center gap-3 group">
                                            <svg class="w-6 h-6 group-hover:scale-125 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                            I HAVE MY VOTER ID
                                        </button>
                                    </form>

                                    <% if (extraData.isEnrollmentOpen) { %>
                                        <form action="/simulate/next-stage" method="POST">
                                            <input type="hidden" name="action" value="REGISTER_FORM_6">
                                            <button type="submit" class="w-full bg-eci-blue text-white px-8 py-5 rounded-2xl font-black text-lg hover:bg-blue-800 transition shadow-xl hover:shadow-blue-100 flex items-center justify-center gap-3 group">
                                                <svg class="w-6 h-6 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                                REGISTER (FORM 6)
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <!-- Negative Path -->
                                        <form action="/simulate/next-stage" method="POST">
                                            <input type="hidden" name="action" value="PROVIDE_ID">
                                            <input type="hidden" name="hasID" value="">
                                            <button type="submit" class="w-full bg-gray-100 text-gray-400 px-8 py-5 rounded-2xl font-black text-lg hover:bg-red-50 hover:text-red-600 transition flex items-center justify-center gap-3 group">
                                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                                I DON'T HAVE AN ID
                                            </button>
                                        </form>
                                    <% } %>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>

                <!-- Guide Cards & Interaction -->
                <div class="grid md:grid-cols-3 gap-6">
                    <!-- Card 1: Check E-roll -->
                    <div class="group p-8 bg-white border border-gray-100 rounded-3xl shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-2 cursor-pointer" onclick="togglePrepInfo('e-roll')">
                        <div class="w-14 h-14 bg-blue-50 text-eci-blue rounded-2xl flex items-center justify-center mb-6 group-hover:bg-eci-blue group-hover:text-white transition-colors duration-500">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                        </div>
                        <h4 class="text-xl font-black text-gray-900 mb-2">Check E-roll</h4>
                        <p class="text-sm text-gray-500 leading-relaxed">Ensure your name is listed in the final constituency records.</p>
                        <div id="info-e-roll" class="hidden mt-4 p-4 bg-blue-50 rounded-xl text-xs text-blue-800 animate-fade-in">
                            <p class="font-bold mb-2">Instructions:</p>
                            <ul class="list-disc ml-4 space-y-1">
                                <li>Visit electoralsearch.eci.gov.in</li>
                                <li>Search by EPIC No. or Details</li>
                                <li>Verify Part No. and Serial No.</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Card 2: e-EPIC Card -->
                    <div class="group p-8 bg-white border border-gray-100 rounded-3xl shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-2 cursor-pointer" onclick="togglePrepInfo('epic')">
                        <div class="w-14 h-14 bg-blue-50 text-eci-blue rounded-2xl flex items-center justify-center mb-6 group-hover:bg-eci-blue group-hover:text-white transition-colors duration-500">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        </div>
                        <h4 class="text-xl font-black text-gray-900 mb-2">e-EPIC Card</h4>
                        <p class="text-sm text-gray-500 leading-relaxed">Download your digital ID instantly for paperless verification.</p>
                        <div id="info-epic" class="hidden mt-4 p-4 bg-green-50 rounded-xl text-xs text-green-800 animate-fade-in">
                            <p class="font-bold mb-2">Verification Steps:</p>
                            <p>Download the Voter Helpline App. Login with your registered mobile number to access your secure digital Voter ID with QR code.</p>
                        </div>
                    </div>

                    <!-- Card 3: Locate Booth -->
                    <div class="group p-8 bg-white border border-gray-100 rounded-3xl shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-2 cursor-pointer" onclick="togglePrepInfo('booth')">
                        <div class="w-14 h-14 bg-blue-50 text-eci-blue rounded-2xl flex items-center justify-center mb-6 group-hover:bg-eci-blue group-hover:text-white transition-colors duration-500">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </div>
                        <h4 class="text-xl font-black text-gray-900 mb-2">Locate Booth</h4>
                        <p class="text-sm text-gray-500 leading-relaxed">Know your polling station address and entrance gate details.</p>
                        <div id="info-booth" class="hidden mt-4 p-4 bg-eci-blue text-white rounded-xl text-xs animate-fade-in">
                            <p class="font-black mb-2">Your Assigned Booth:</p>
                            <div class="p-3 bg-white/10 rounded-lg">
                                <p class="font-bold">Station: <%= voterData.location.constituency %> Public School</p>
                                <p>Zone: <%= voterData.location.pinCode.substring(0,3) %>-South</p>
                                <p>Pincode: <%= voterData.location.pinCode %></p>
                            </div>
                        </div>
                    </div>
                </div>

                <script>
                    function togglePrepInfo(id) {
                        const el = document.getElementById('info-' + id);
                        const isHidden = el.classList.contains('hidden');
                        
                        // Close all others
                        document.querySelectorAll('[id^="info-"]').forEach(item => item.classList.add('hidden'));
                        
                        if (isHidden) {
                            el.classList.remove('hidden');
                        }
                    }
                </script>
            </div>
        <% } else if (state === 'CAMPAIGN') { %>
            <div class="space-y-10 animate-fade-in">
                <div class="flex justify-between items-center border-b border-gray-100 pb-8">
                    <div class="flex items-center gap-4">
                        <div class="w-16 h-16 bg-eci-orange text-white rounded-3xl flex items-center justify-center shadow-lg shadow-orange-100">
                            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
                        </div>
                        <div>
                            <h2 class="text-4xl font-black text-gray-900 tracking-tight">Spot the Lie!</h2>
                            <p class="text-lg text-gray-500 font-medium">Round <%= extraData.newsProgress %> of 3</p>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <% for(let i=0; i<3; i++) { %>
                            <div class="w-12 h-2 rounded-full <%= i < voterData.campaignIndex ? 'bg-green-500' : (i === voterData.campaignIndex ? 'bg-eci-orange animate-pulse' : 'bg-gray-200') %>"></div>
                        <% } %>
                    </div>
                </div>

                <div class="space-y-2">
                    <p class="text-xl text-gray-600 font-medium">Two stories. One is true. One is a lie.</p>
                    <p class="text-lg text-gray-500">Pick the one you trust.</p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-4">
                    <!-- Headline A (Fake) -->
                    <form action="/simulate/next-stage" method="POST" class="contents">
                        <input type="hidden" name="action" value="NEXT_NEWS">
                        <input type="hidden" name="isScammed" value="true">
                        <input type="hidden" name="scamHeadline" value="<%= extraData.headlines.fake %>">
                        <button type="submit" class="group relative overflow-hidden p-10 bg-white border-2 border-gray-100 rounded-[2.5rem] shadow-sm hover:shadow-2xl hover:border-eci-orange transition-all duration-500 text-left">
                            <div class="absolute top-0 right-0 p-6 opacity-10 group-hover:opacity-100 transition-opacity">
                                <svg class="w-12 h-12 text-eci-orange" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                            </div>
                            <span class="text-xs font-black text-gray-400 uppercase tracking-widest block mb-4 group-hover:text-eci-orange transition-colors">News A</span>
                            <p class="text-2xl font-black text-gray-800 leading-tight group-hover:text-gray-900 transition-colors">
                                "<%= extraData.headlines.fake %>"
                            </p>
                            <div class="mt-8 flex items-center gap-2 text-eci-orange font-bold text-sm opacity-0 group-hover:opacity-100 transition-opacity">
                                This is my answer <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                            </div>
                        </button>
                    </form>

                    <!-- Headline B (Real) -->
                    <form action="/simulate/next-stage" method="POST" class="contents">
                        <input type="hidden" name="action" value="NEXT_NEWS">
                        <input type="hidden" name="isScammed" value="">
                        <button type="submit" class="group relative overflow-hidden p-10 bg-white border-2 border-gray-100 rounded-[2.5rem] shadow-sm hover:shadow-2xl hover:border-eci-blue transition-all duration-500 text-left">
                            <div class="absolute top-0 right-0 p-6 opacity-10 group-hover:opacity-100 transition-opacity">
                                <svg class="w-12 h-12 text-eci-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                            </div>
                            <span class="text-xs font-black text-gray-400 uppercase tracking-widest block mb-4 group-hover:text-eci-blue transition-colors">News B</span>
                            <p class="text-2xl font-black text-gray-800 leading-tight group-hover:text-gray-900 transition-colors">
                                "<%= extraData.headlines.real %>"
                            </p>
                            <div class="mt-8 flex items-center gap-2 text-eci-blue font-bold text-sm opacity-0 group-hover:opacity-100 transition-opacity">
                                This is my answer <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                            </div>
                        </button>
                    </form>
                </div>

                <div class="bg-blue-50 border border-blue-100 p-8 rounded-3xl flex gap-6 items-center">
                    <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-eci-blue shrink-0 text-2xl">🤔</div>
                    <div class="space-y-1">
                        <p class="text-blue-900 font-black">How to spot a lie?</p>
                        <p class="text-blue-800 text-sm">Fake news sounds too good or too scary.</p>
                        <p class="text-blue-800 text-sm">Real news uses normal, calm words.</p>
                        <p class="text-blue-800 text-sm">Check: Does any official website say this?</p>
                    </div>
                </div>
            </div>
        <% } else if (state === 'POLL') { %>
            <div class="space-y-10 animate-fade-in">
                <div class="flex items-center gap-4 border-b border-gray-100 pb-8">
                    <div class="w-16 h-16 bg-eci-blue text-white rounded-3xl flex items-center justify-center shadow-lg shadow-blue-100 text-3xl">🗳️</div>
                    <div>
                        <h2 class="text-4xl font-black text-gray-900 tracking-tight">It's Voting Day!</h2>
                        <p class="text-lg text-gray-500 font-medium">You are at your booth. Pick one person.</p>
                    </div>
                </div>

                <% if (voterData.hasID && !voterData.isScammed) { %>

                    <!-- Booth location map -->
                    <div class="relative rounded-[2rem] overflow-hidden shadow-xl border-4 border-white">
                        <img src="<%= extraData.mapsUrl %>" alt="Booth Location" class="w-full h-52 object-cover">
                        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-6">
                            <p class="text-white font-black text-lg"><%= voterData.location.constituency %> Govt School</p>
                            <p class="text-gray-300 text-sm">Booth No. 142 | Ground Floor, Room 4</p>
                        </div>
                    </div>

                    <div class="p-4 bg-blue-50 border border-blue-100 rounded-2xl text-sm text-blue-900 font-bold">
                        ✅ Your name is in the list. Your ID is ready. You can vote now.
                    </div>

                    <!-- Disclaimer -->
                    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-2xl text-xs text-yellow-800 font-semibold italic">
                        ⚠️ These names are made up. We don't want to pick real names because we don't want to pick sides. This is just for learning.
                    </div>

                    <!-- Candidate Cards -->
                    <div class="space-y-4">
                        <h3 class="text-xl font-black text-gray-800">Read each person's info. Then vote.</h3>
                        <p class="text-sm text-gray-500">Hover the <span class="logic-analogy text-xs">orange words<span class="analogy-bubble">Village Analogy appears here!</span></span> to understand hard words.</p>

                        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 mt-4">
                        <% extraData.candidates.forEach(function(c) { %>
                            <form action="/simulate/next-stage" method="POST">
                                <input type="hidden" name="action" value="VOTE">
                                <input type="hidden" name="candidateChoice" value="<%= c.id %>">
                                <button type="submit" class="group w-full text-left p-6 bg-white border-2 border-gray-100 rounded-3xl shadow-sm hover:shadow-xl hover:border-eci-blue transition-all duration-300">
                                    <div class="flex items-center gap-3 mb-4">
                                        <span class="text-3xl"><%= c.symbol %></span>
                                        <div>
                                            <p class="text-xs font-black text-gray-400 uppercase tracking-widest"><%= c.nickname %></p>
                                            <p class="text-xl font-black text-gray-900"><%= c.name %></p>
                                        </div>
                                    </div>
                                    <p class="text-sm font-bold text-eci-blue mb-4 bg-blue-50 rounded-xl px-3 py-2">"<%= c.promise %>"</p>

                                    <!-- Form 26 info with LogicAnalogy -->
                                    <div class="space-y-1.5 text-xs text-gray-600 border-t border-gray-100 pt-3">
                                        <p class="font-black text-gray-400 uppercase tracking-wider mb-2">From their Form 26 (their public report card):</p>
                                        <p>
                                            <span class="logic-analogy">
                                                <%= extraData.form26Analogies.assets.label %>
                                                <span class="analogy-bubble"><%= extraData.form26Analogies.assets.tip %></span>
                                            </span>: <%= c.form26.assets %>
                                        </p>
                                        <p>
                                            <span class="logic-analogy">
                                                <%= extraData.form26Analogies.liabilities.label %>
                                                <span class="analogy-bubble"><%= extraData.form26Analogies.liabilities.tip %></span>
                                            </span>: <%= c.form26.liabilities %>
                                        </p>
                                        <p>
                                            <span class="logic-analogy">
                                                <%= extraData.form26Analogies.cases.label %>
                                                <span class="analogy-bubble"><%= extraData.form26Analogies.cases.tip %></span>
                                            </span>: <%= c.form26.cases %>
                                        </p>
                                        <p>
                                            <span class="logic-analogy">
                                                <%= extraData.form26Analogies.education.label %>
                                                <span class="analogy-bubble"><%= extraData.form26Analogies.education.tip %></span>
                                            </span>: <%= c.form26.education %>
                                        </p>
                                    </div>

                                    <div class="mt-4 text-center text-eci-blue font-black text-sm opacity-0 group-hover:opacity-100 transition-opacity">
                                        ✅ Vote for <%= c.name %>
                                    </div>
                                </button>
                            </form>
                        <% }); %>
                        </div>
                    </div>

                <% } else { %>
                    <!-- Ineligible voter panel -->
                    <div class="bg-red-50 border-2 border-red-100 rounded-[2.5rem] p-10 shadow-2xl shadow-red-50 animate-fade-in relative overflow-hidden">
                        <div class="absolute -right-10 -top-10 w-32 h-32 bg-red-100 rounded-full blur-2xl opacity-50"></div>
                        <h3 class="text-3xl font-black text-red-900 mb-2">You Cannot Vote Today.</h3>
                        <p class="text-gray-600 mb-6">Here is why:</p>
                        <div class="space-y-4 mb-8">
                            <% if (!voterData.hasID) { %>
                                <div class="flex gap-3 text-red-700 bg-red-100 rounded-2xl p-4">
                                    <span class="text-2xl">🪪</span>
                                    <p class="font-bold">No Voter ID. You did not bring your ID card. The officer turned you away.</p>
                                </div>
                            <% } %>
                            <% if (voterData.isScammed) { %>
                                <div class="flex gap-3 text-red-700 bg-red-100 rounded-2xl p-4">
                                    <span class="text-2xl">🚫</span>
                                    <div class="space-y-1">
                                        <p class="font-black text-sm uppercase tracking-widest opacity-70">You believed a lie.</p>
                                        <p class="font-bold">You trusted this fake news: "<%= voterData.scamHeadline %>"</p>
                                        <p class="text-sm opacity-80">It sent you to the wrong place. You missed your voting time.</p>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                        <form action="/simulate/next-stage" method="POST">
                            <input type="hidden" name="action" value="VOTE">
                            <button type="submit" class="w-full py-5 bg-gray-900 text-white rounded-2xl font-black text-xl hover:bg-black transition-all shadow-xl">
                                See What Happens Next →
                            </button>
                        </form>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
</div>


