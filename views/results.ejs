<%- include('partials/header') %>

<div class="max-w-4xl mx-auto py-12 px-4 animate-fade-in">
    <!-- Results Card -->
    <div class="bg-white rounded-[3rem] shadow-2xl overflow-hidden border border-gray-100 relative">
        <!-- Top Banner -->
        <div class="<%= results.winner === 'Your Candidate' ? 'bg-green-600' : 'bg-red-600' %> p-12 text-center relative overflow-hidden">
            <div class="absolute inset-0 opacity-10">
                <svg class="w-full h-full" fill="none" viewBox="0 0 100 100" preserveAspectRatio="none">
                    <path d="M0 100 L100 0" stroke="white" stroke-width="1"/>
                    <path d="M0 0 L100 100" stroke="white" stroke-width="1"/>
                </svg>
            </div>
            
            <div class="relative z-10">
                <h2 class="text-5xl font-black text-white mb-2 tracking-tighter">FINAL VERDICT</h2>
                <p class="text-white/80 uppercase tracking-[0.3em] font-black text-sm">The Butterfly Effect Simulation</p>
            </div>
        </div>

        <div class="p-12 space-y-12">
            <!-- Scoreboard -->
            <div class="flex flex-col md:flex-row justify-between items-center gap-8">
                <div class="text-center space-y-3 group">
                    <div class="text-xs font-black text-gray-400 uppercase tracking-widest group-hover:text-eci-blue transition-colors">Your Choice</div>
                    <div class="text-7xl font-black text-gray-900 tracking-tighter tabular-nums"><%= results.votes.candidate %></div>
                    <div class="w-12 h-1.5 bg-eci-blue mx-auto rounded-full opacity-20 group-hover:opacity-100 transition-opacity"></div>
                </div>

                <div class="flex flex-col items-center">
                    <div class="text-2xl font-black text-gray-200 mb-2 italic">VS</div>
                    <div class="px-6 py-2 bg-gray-50 border border-gray-100 rounded-full text-xs font-black text-gray-500 uppercase tracking-widest">Margin: <%= results.margin %></div>
                </div>

                <div class="text-center space-y-3 group">
                    <div class="text-xs font-black text-gray-400 uppercase tracking-widest group-hover:text-red-600 transition-colors">Opponent</div>
                    <div class="text-7xl font-black text-gray-900 tracking-tighter tabular-nums"><%= results.votes.opponent %></div>
                    <div class="w-12 h-1.5 bg-red-600 mx-auto rounded-full opacity-20 group-hover:opacity-100 transition-opacity"></div>
                </div>
            </div>

            <!-- Big Message -->
            <div class="bg-gray-50 rounded-[2.5rem] p-10 text-center relative overflow-hidden group">
                <div class="absolute -right-10 -top-10 w-40 h-40 bg-white rounded-full opacity-50 blur-3xl group-hover:scale-150 transition-transform duration-700"></div>
                <h3 class="text-3xl font-black text-gray-900 mb-4 relative z-10">
                    <%= results.winner === 'Your Candidate' ? 'Your vote won the day!' : 'A narrow defeat...' %>
                </h3>
                <p class="text-xl text-gray-600 font-medium italic relative z-10 leading-relaxed">
                    "<%= results.message %>"
                </p>
            </div>

            <!-- Decision Audit -->
            <div class="space-y-6">
                <h4 class="text-xs font-black text-gray-400 uppercase tracking-widest border-b border-gray-100 pb-4">Decision Audit Log</h4>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="p-6 rounded-3xl <%= results.hasID ? 'bg-green-50 border-green-100' : 'bg-red-50 border-red-100' %> border flex items-center gap-4">
                        <div class="w-10 h-10 rounded-2xl <%= results.hasID ? 'bg-green-600' : 'bg-red-600' %> text-white flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="<%= results.hasID ? 'M5 13l4 4L19 7' : 'M6 18L18 6M6 6l12 12' %>"></path></svg>
                        </div>
                        <div>
                            <p class="text-xs font-black text-gray-400 uppercase">Identity</p>
                            <p class="font-bold text-gray-800"><%= results.hasID ? 'Verified' : 'Failed' %></p>
                        </div>
                    </div>

                    <div class="p-6 rounded-3xl <%= !results.isScammed ? 'bg-green-50 border-green-100' : 'bg-red-50 border-red-100' %> border flex items-center gap-4">
                        <div class="w-10 h-10 rounded-2xl <%= !results.isScammed ? 'bg-green-600' : 'bg-red-600' %> text-white flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="<%= !results.isScammed ? 'M9 12l2 2 4-4m5.618-4.016A3.323 3.323 0 0010.603 2L9 22.887a1 1 0 01-1.07.742c-3.15-.394-5.83-2.615-6.93-5.54a1 1 0 01.37-1.16l14.248-11.943a1 1 0 011.605.352z' : 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z' %>"></path></svg>
                        </div>
                        <div>
                            <p class="text-xs font-black text-gray-400 uppercase">Information</p>
                            <p class="font-bold text-gray-800"><%= results.isScammed ? 'Misinformed' : 'Grounded' %></p>
                        </div>
                    </div>

                    <div class="p-6 rounded-3xl <%= results.voted ? 'bg-green-50 border-green-100' : 'bg-red-50 border-red-100' %> border flex items-center gap-4">
                        <div class="w-10 h-10 rounded-2xl <%= results.voted ? 'bg-green-600' : 'bg-red-600' %> text-white flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5"></path></svg>
                        </div>
                        <div>
                            <p class="text-xs font-black text-gray-400 uppercase">Action</p>
                            <p class="font-bold text-gray-800"><%= results.voted ? 'Voted' : 'No Action' %></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer Action -->
            <div class="pt-8 text-center">
                <a href="/api/reset-session" class="inline-flex items-center gap-3 bg-gray-900 text-white px-12 py-5 rounded-3xl font-black text-xl hover:bg-black transition-all shadow-2xl hover:shadow-gray-200 transform hover:-translate-y-1 group">
                    <svg class="w-6 h-6 group-hover:rotate-180 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    RESTART JOURNEY
                </a>
                <p class="mt-6 text-sm text-gray-400 font-bold uppercase tracking-widest">Attempt #<%= locals.attemptCount || 1 %></p>
            </div>
        </div>
    </div>

    <!-- Educational Footer -->
    <div class="mt-12 text-center space-y-4">
        <div class="flex justify-center gap-4 text-gray-300">
            <div class="w-2 h-2 bg-current rounded-full"></div>
            <div class="w-2 h-2 bg-current rounded-full"></div>
            <div class="w-2 h-2 bg-current rounded-full"></div>
        </div>
        <p class="text-lg text-gray-500 font-medium max-w-2xl mx-auto leading-relaxed">
            Every election is a story written by millions. In this simulation, you saw how easily one voice can be lost—or found.
        </p>
        <p class="text-xs font-black text-gray-300 uppercase tracking-[0.5em]">CivicLogic × ECI 2026</p>
    </div>
</div>

<%- include('partials/footer') %>
