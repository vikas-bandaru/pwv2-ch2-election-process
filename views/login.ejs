<%- include('partials/header') %>



<div class="max-w-md mx-auto bg-white rounded-xl shadow-md overflow-hidden md:max-w-2xl mt-10 p-8 border-t-4 border-eci-blue">
    <% if (locals.attemptCount && locals.attemptCount > 0) { %>
        <div class="mb-4 text-center">
            <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-bold uppercase tracking-widest">
                Session History: Attempt #<%= locals.attemptCount + 1 %>
            </span>
        </div>
    <% } %>

    <h2 class="text-3xl font-bold text-gray-800 mb-2 text-center">Civic Role Selection</h2>
    <p class="text-gray-600 mb-8 text-center">Select your role to begin the democratic simulation.</p>
    
    <form action="/auth/login" method="POST" id="loginForm" class="space-y-8">
        <!-- Role Selection Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <label class="relative cursor-pointer group">
                <input type="radio" name="role" value="VOTER" checked class="peer sr-only">
                <div class="p-4 border-2 border-gray-100 rounded-xl transition-all duration-200 peer-checked:border-eci-blue peer-checked:bg-blue-50 group-hover:border-blue-200">
                    <div class="text-3xl mb-2">🗳️</div>
                    <div class="font-bold text-gray-800">Voter</div>
                    <div class="text-[10px] text-gray-500 leading-tight">Research, choose, and cast your vote.</div>
                </div>
                <div class="absolute -top-2 -right-2 bg-eci-blue text-white text-[8px] font-black px-2 py-0.5 rounded-full opacity-0 peer-checked:opacity-100 transition-opacity">ACTIVE</div>
            </label>

            <label class="relative cursor-pointer group">
                <input type="radio" name="role" value="CANDIDATE" class="peer sr-only">
                <div class="p-4 border-2 border-gray-100 rounded-xl transition-all duration-200 peer-checked:border-eci-blue peer-checked:bg-blue-50 group-hover:border-blue-200">
                    <div class="text-3xl mb-2">📢</div>
                    <div class="font-bold text-gray-800">Candidate</div>
                    <div class="text-[10px] text-gray-500 leading-tight">File nomination and run campaigns.</div>
                </div>
                <div class="absolute -top-2 -right-2 bg-amber-500 text-white text-[8px] font-black px-2 py-0.5 rounded-full opacity-100">BETA</div>
            </label>

            <label class="relative cursor-pointer group">
                <input type="radio" name="role" value="OFFICER" class="peer sr-only">
                <div class="p-4 border-2 border-gray-100 rounded-xl transition-all duration-200 peer-checked:border-eci-blue peer-checked:bg-blue-50 group-hover:border-blue-200">
                    <div class="text-3xl mb-2">👨‍⚖️</div>
                    <div class="font-bold text-gray-800">Officer</div>
                    <div class="text-[10px] text-gray-500 leading-tight">Oversee the booth and seal machines.</div>
                </div>
                <div class="absolute -top-2 -right-2 bg-amber-500 text-white text-[8px] font-black px-2 py-0.5 rounded-full opacity-100">BETA</div>
            </label>
        </div>

        <div class="space-y-4">
            <div>
                <label for="name" class="block text-sm font-bold text-gray-700">Enter Your Name</label>
                <input type="text" name="name" id="name" required 
                    class="mt-1 block w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm
                    focus:outline-none focus:border-eci-blue focus:ring-2 focus:ring-blue-100 transition"
                    placeholder="Vikas Bandaru">
            </div>
            
            <button type="submit" 
                class="w-full bg-eci-blue text-white py-4 rounded-xl font-black text-sm uppercase tracking-widest hover:bg-blue-800 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                START SIMULATION →
            </button>
        </div>
    </form>
</div>

<%- include('partials/footer') %>
